{
    "command": "/usr/bin/ironic-neutron-agent --config-file /usr/share/ironic/ironic_neutron_agent.conf --config-file /etc/neutron/neutron.conf --config-dir /etc/neutron/neutron.conf.d",
    "config_files": [
        {
            "source": "/var/lib/config-data/default/01-ironic_neutron_agent.conf",
            "dest": "/etc/neutron/plugins/ml2/01-ironic_neutron_agent.conf",
            "owner": "root:neutron",
            "perm": "0600"
        },
        {
            "source": "/var/lib/config-data/merged/custom.conf",
            "dest": "/etc/neutron/neutron.conf.d/custom.conf",
            "owner": "neutron",
            "perm": "0600"
        }
    ],
    "permissions": [
        {
            "path": "/var/log/neutron",
            "owner": "neutron:neutron",
            "recurse": true
        }
    ]
}
